# Copy this file to .env and fill in real values. NEVER commit the real .env.
# After any suspected exposure, ROTATE every secret below in its provider dashboard.

NODE_ENV="development"          # set to "production" when deployed

DB_NAME="V-Talk"
MONGO_URL=""                    # MongoDB Atlas connection string

JWT_SECRET=""                   # long random string, e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"`

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

SMPT_SERVICES="gmail"
SMPT_MAIL=""                    # sender email address
SMPT_PASSWORD=""                # Gmail App Password (not the account password)
SMPT_HOST="smtp.gmail.com"
SMPT_PORT=587

PORT=4000
CLIENT_ACCESS_URL="http://localhost:3000"   # origin allowed for CORS + sockets
